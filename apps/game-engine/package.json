{
  "name": "@branchout/game-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Branch out game-engine - runs games and holds live session state over WebSocket.",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@branchout/game-liar-liar": "workspace:*",
    "@branchout/game-sdk": "workspace:*",
    "@branchout/game-teeter-tower": "workspace:*",
    "@branchout/game-trivia": "workspace:*",
    "@branchout/protocol": "workspace:*",
    "@branchout/service-runtime": "workspace:*",
    "fastify": "^5.2.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@branchout/config": "workspace:*",
    "@types/node": "^20.17.10",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
