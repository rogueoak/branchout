{
  "name": "@branchout/service-runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Shared runtime helpers for the Branch out Fastify services (env parsing, Redis).",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@branchout/config": "workspace:*",
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
