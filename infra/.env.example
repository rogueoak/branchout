# Copy to infra/.env before running docker compose. These values are for LOCAL dev only;
# a real deployment supplies its own secrets through the environment, never a committed file.

# Postgres (the control-plane's system of record)
POSTGRES_USER=branchout
POSTGRES_PASSWORD=branchout
POSTGRES_DB=branchout

# Connection strings the services read. Host names match the compose service names.
DATABASE_URL=postgres://branchout:branchout@postgres:5432/branchout
REDIS_URL=redis://redis:6379

# Ports exposed on the host
WEB_PORT=3000
CONTROL_PLANE_PORT=4000
GAME_ENGINE_PORT=4001

# Newsletter subscribe / Constant Contact (spec 0047). Leave these UNSET for local dev: the
# POST /v1/subscribe endpoint stays inert and returns a clear "Subscribe is not configured yet."
# response instead of calling Constant Contact. To turn it on, an operator provisions the three
# CTCT secrets: mint CTCT_REFRESH_TOKEN via the `ctct` CLI (`ctct login`) and find the "Branch Out"
# list id via `ctct list list --name "Branch Out"`.
# CTCT_CLIENT_ID=
# CTCT_REFRESH_TOKEN=
# CTCT_LIST_ID=
# Per-IP rate limit for the subscribe endpoint (defaults: 5 attempts / 600s window).
# SUBSCRIBE_MAX_PER_IP=5
# SUBSCRIBE_WINDOW_SECONDS=600
