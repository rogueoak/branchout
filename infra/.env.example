# Copy to infra/.env before running docker compose. These values are for LOCAL dev only;
# a real deployment supplies its own secrets through the environment, never a committed file.

# Postgres (the control-plane's system of record)
POSTGRES_USER=branchout
POSTGRES_PASSWORD=branchout
POSTGRES_DB=branchout

# Connection strings the services read. Host names match the compose service names.
DATABASE_URL=postgres://branchout:branchout@postgres:5432/branchout
REDIS_URL=redis://redis:6379

# Ports exposed on the host
WEB_PORT=3000
CONTROL_PLANE_PORT=4000
GAME_ENGINE_PORT=4001

# Engine-join authentication (spec 0064). A shared HMAC secret: the control-plane mints a per-
# connection token over the caller's own membership, and the game-engine verifies it on the
# WebSocket join, so a device cannot impersonate another player and read their private payloads. The
# SAME value must reach both services. Set it in dev so the real auth path is exercised (the compose
# file passes it to control-plane AND game-engine). Leave it UNSET only for a pure-unit scenario:
# then the control-plane's token endpoint returns "not configured" and the engine skips enforcement.
# Generate a real one with `openssl rand -hex 32`.
ENGINE_AUTH_SECRET=dev-engine-auth-secret

# Host in-game feedback email (spec 0048). Sent via Resend from branchout@rogueoak.com to
# feedback@rogueoak.com. Leave RESEND_API_KEY unset in dev: the endpoint then returns a clear
# "not configured" response instead of sending (and never crashes). To actually deliver, set a
# real key AND verify rogueoak.com as a Resend sending domain. The per-IP cap reuses the auth
# limiter; defaults are 5 submissions / 600s.
# RESEND_API_KEY=
FEEDBACK_MAX_PER_IP=5
FEEDBACK_WINDOW_SECONDS=600

# Newsletter subscribe / Constant Contact (spec 0047). Leave these UNSET for local dev: the
# POST /v1/subscribe endpoint stays inert and returns a clear "Subscribe is not configured yet."
# response instead of calling Constant Contact. To turn it on, an operator provisions the three
# CTCT secrets: mint CTCT_REFRESH_TOKEN via the `ctct` CLI (`ctct login`) and find the "Branch Out"
# list id via `ctct list list --name "Branch Out"`.
# CTCT_CLIENT_ID=
# CTCT_REFRESH_TOKEN=
# CTCT_LIST_ID=
# Per-IP rate limit for the subscribe endpoint (defaults: 5 attempts / 600s window).
# SUBSCRIBE_MAX_PER_IP=5
# SUBSCRIBE_WINDOW_SECONDS=600
