# Caddy edge config for branchout.games.
# Auto-TLS via ACME (Let's Encrypt). No email in this file (operator privacy;
# set `email` in a local /etc/caddy/Caddyfile override on the host if needed).
#
# Same-origin path routing: one domain, one TLS certificate, no CORS. All functional APIs are
# served under the `/v1` version prefix (spec 0033); `/health` stays unversioned.
#   /api/v1/*  -> control-plane:4000  (REST, e.g. /api/v1/auth/login -> /v1/auth/login)
#   /ws/*      -> game-engine:4001    (WebSocket upgrade; the browser connects to /ws/v1)
#   *          -> web:3000            (Next.js)
#
# Validate before applying:
#   docker compose -f deploy/docker/compose.proxy.yml exec caddy caddy validate --config /etc/caddy/Caddyfile

{
    # No ACME email here. Add `email you@example.com` in a host-local override
    # snippet (/etc/caddy/Caddyfile.d/*.caddy) if you want expiry notifications.
}

# Redirect www to apex (permanent).
www.branchout.games {
    redir https://branchout.games{uri} permanent
}

branchout.games {
    encode gzip zstd

    # HSTS: tell browsers to always use HTTPS for this domain (2 years).
    header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

    # Zero-downtime deploys (spec 0034): every upstream below uses DYNAMIC A-record
    # resolution instead of a static `reverse_proxy host:port`. A static upstream
    # resolves the service name once and caches the IP, so after a docker-rollout swap
    # (a new Compose-indexed instance replaces the old) Caddy would keep hitting the
    # GONE container. `dynamic a` re-resolves the service alias against Docker's embedded
    # DNS (127.0.0.11) every second, so Caddy load-balances across whatever instances are
    # live and follows the swap; during a rollout both resolve, and when the old one is
    # removed the next refresh drops it. `lb_try_duration`/`lb_retries` retry onto a live
    # instance and `fail_duration` (connect-failures only, no `unhealthy_status`, so a
    # genuine app 5xx never benches the sole steady-state upstream) closes the <=1s window
    # where the cached set still lists the departed IP. See overview/architecture.md.

    # WebSocket upgrade - game-engine handles /ws traffic. The browser connects to the versioned
    # /ws/v1 (spec 0033), but the engine's ws server accepts any path (room/game/player come from the
    # `join` frame), so no prefix strip is needed; match both bare /ws and /ws/* (which covers /ws/v1).
    # Caddy preserves the Upgrade header automatically on a WebSocket handshake, dynamic upstream included.
    @ws path /ws /ws/*
    handle @ws {
        reverse_proxy {
            dynamic a {
                name game-engine
                port 4001
                refresh 1s
                resolvers 127.0.0.11
                versions ipv4
                dial_timeout 3s
            }
            lb_try_duration 5s
            lb_retries 3
            fail_duration 2s
        }
    }

    # The engine report intake (control-plane /v1/engine/*) is internal-only: the
    # game-engine calls it over the container network, never the browser. Block it
    # from the internet so the (currently unauthenticated) money endpoint is not
    # reachable from outside. Must come before the general /api proxy below.
    handle /api/v1/engine/* {
        respond 404
    }

    # REST API - control-plane serves /v1/auth, /v1/rooms, /v1/engine (no /api prefix),
    # so handle_path STRIPS /api before proxying: /api/v1/auth/login -> /v1/auth/login.
    handle_path /api/* {
        reverse_proxy {
            dynamic a {
                name control-plane
                port 4000
                refresh 1s
                resolvers 127.0.0.11
                versions ipv4
                dial_timeout 3s
            }
            lb_try_duration 5s
            lb_retries 3
            fail_duration 2s
        }
    }

    # Everything else goes to the Next.js web app.
    handle {
        reverse_proxy {
            dynamic a {
                name web
                port 3000
                refresh 1s
                resolvers 127.0.0.11
                versions ipv4
                dial_timeout 3s
            }
            lb_try_duration 5s
            lb_retries 3
            fail_duration 2s
        }
    }
}
