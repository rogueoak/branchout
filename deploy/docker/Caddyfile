# Caddy edge config for branchout.games.
# Auto-TLS via ACME (Let's Encrypt). No email in this file (operator privacy;
# set `email` in a local /etc/caddy/Caddyfile override on the host if needed).
#
# Same-origin path routing: one domain, one TLS certificate, no CORS. All functional APIs are
# served under the `/v1` version prefix (spec 0033); `/health` stays unversioned.
#   /api/v1/*  -> control-plane:4000  (REST, e.g. /api/v1/auth/login -> /v1/auth/login)
#   /ws/*      -> game-engine:4001    (WebSocket upgrade; the browser connects to /ws/v1)
#   *          -> web:3000            (Next.js)
#
# The apex and the insider subdomain (spec 0035) share this exact routing - the insider surface is
# served by the same `web` process (host-aware middleware rewrites it), and re-serving /api + /ws
# same-origin under insider keeps it CORS-free. To stay DRY the routing lives in snippets
# (`ws`, `api`, `api_ws`, `web`) that each site block imports. Admin (spec 0037) is a separate Next.js
# service on its own block; it imports `api` (no `/ws`) and proxies the rest to the `admin` service.
#
# Validate before applying:
#   docker compose -f deploy/docker/compose.proxy.yml exec caddy caddy validate --config /etc/caddy/Caddyfile

{
    # No ACME email here. Add `email you@example.com` in a host-local override
    # snippet (/etc/caddy/Caddyfile.d/*.caddy) if you want expiry notifications.
}

# Zero-downtime deploys (spec 0034): every upstream below uses DYNAMIC A-record
# resolution instead of a static `reverse_proxy host:port`. A static upstream
# resolves the service name once and caches the IP, so after a docker-rollout swap
# (a new Compose-indexed instance replaces the old) Caddy would keep hitting the
# GONE container. `dynamic a` re-resolves the service alias against Docker's embedded
# DNS (127.0.0.11) every second, so Caddy load-balances across whatever instances are
# live and follows the swap; during a rollout both resolve, and when the old one is
# removed the next refresh drops it. `lb_try_duration`/`lb_retries` retry onto a live
# instance and `fail_duration` (connect-failures only, no `unhealthy_status`, so a
# genuine app 5xx never benches the sole steady-state upstream) closes the <=1s window
# where the cached set still lists the departed IP. See overview/architecture.md.

# game-engine WebSocket upstream (spec 0033). The browser connects to the versioned /ws/v1, but the
# engine's ws server accepts any path (room/game/player come from the `join` frame), so no prefix strip
# is needed; match both bare /ws and /ws/*. Caddy preserves the Upgrade header automatically on a
# WebSocket handshake, dynamic upstream included.
(ws) {
    @ws path /ws /ws/*
    handle @ws {
        reverse_proxy {
            dynamic a {
                name game-engine
                port 4001
                refresh 1s
                resolvers 127.0.0.11
                versions ipv4
                dial_timeout 3s
            }
            lb_try_duration 5s
            lb_retries 3
            fail_duration 2s
        }
    }
}

# control-plane REST upstream. Owns the trusted-client-IP header (spec 0038) so EVERY block that fronts
# control-plane's /api - apex, insider, and admin (spec 0037) - inherits an unforgeable request.ip from
# ONE place, never a per-block copy that could drift out of sync.
(api) {
    # The engine report intake (control-plane /v1/engine/*) is internal-only: the game-engine calls it
    # over the container network, never the browser. Block it from the internet so the (currently
    # unauthenticated) money endpoint is not reachable from outside. Must come before the general /api.
    handle /api/v1/engine/* {
        respond 404
    }

    # REST API - control-plane serves /v1/auth, /v1/rooms, /v1/engine (no /api prefix), so handle_path
    # STRIPS /api before proxying: /api/v1/auth/login -> /v1/auth/login.
    handle_path /api/* {
        reverse_proxy {
            dynamic a {
                name control-plane
                port 4000
                refresh 1s
                resolvers 127.0.0.11
                versions ipv4
                dial_timeout 3s
            }
            lb_try_duration 5s
            lb_retries 3
            fail_duration 2s
            # Trustworthy client IP (spec 0038): REPLACE X-Forwarded-For with the true connection peer so
            # control-plane's request.ip cannot be forged. Caddy is the public TLS terminator, so
            # {remote_host} is the real client; without this Caddy appends to a client-supplied XFF and
            # the leftmost value (what trustProxy reads) is attacker-controlled - letting a source rotate
            # past the /auth/signup per-IP cap. Living in this shared snippet means every /api front (apex,
            # insider, admin) gets it. Applies only to the edge-fronted path: a direct dev call to the
            # published control-plane port has no Caddy and no sanitized XFF.
            header_up X-Forwarded-For {remote_host}
        }
    }
}

# API + WebSocket together, for the surfaces that need both (apex, insider). Admin (spec 0037) imports
# `api` alone - it has no WebSocket.
(api_ws) {
    import ws
    import api
}

# Everything else goes to the Next.js web app (the catch-all; must import after api_ws).
(web) {
    handle {
        reverse_proxy {
            dynamic a {
                name web
                port 3000
                refresh 1s
                resolvers 127.0.0.11
                versions ipv4
                dial_timeout 3s
            }
            lb_try_duration 5s
            lb_retries 3
            fail_duration 2s
        }
    }
}

# Cross-cutting settings shared by every first-party host block: compression + HSTS. A new surface
# (spec 0037's admin) gets the same baseline by importing one snippet, so the blocks cannot drift.
(site_base) {
    encode gzip zstd

    # HSTS: tell browsers to always use HTTPS for this domain (2 years).
    header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
}

# Redirect www to apex (permanent).
www.branchout.games {
    redir https://branchout.games{uri} permanent
}

branchout.games {
    import site_base
    import api_ws
    import web
}

# Insider surface (spec 0035): same routing as the apex, served by the same `web` process. The
# host-aware middleware in `web` rewrites requests here into the /insider tree; re-serving /api and
# /ws same-origin keeps the surface CORS-free. Needs an `insider` A record -> the droplet.
insider.branchout.games {
    import site_base
    import api_ws
    import web
}

# Admin console (spec 0037): a SEPARATE Next.js service (`admin`), not the `web` process. It re-serves
# control-plane's /api same-origin (via the shared `api` snippet - so it inherits the trusted-client-IP
# header, spec 0038) and proxies everything else to the admin service. No `/ws` (admin has no
# WebSocket). Needs an `admin` A record -> the droplet. The admin session is a host-only cookie, so it
# never leaves this origin.
admin.branchout.games {
    import site_base
    import api

    handle {
        reverse_proxy {
            dynamic a {
                name admin
                port 3002
                refresh 1s
                resolvers 127.0.0.11
                versions ipv4
                dial_timeout 3s
            }
            lb_try_duration 5s
            lb_retries 3
            fail_duration 2s
        }
    }
}
