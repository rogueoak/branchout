{
  "name": "@rogueoak/branchout",
  "version": "0.0.0",
  "private": true,
  "description": "Branch out - a subscription platform for online shared games.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "pnpm --filter @branchout/e2e e2e"
  },
  "devDependencies": {
    "@branchout/config": "workspace:*",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
